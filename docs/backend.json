{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "Session": {
      "title": "Session",
      "description": "Represents a single data collection session.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the session."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who started the session."
        },
        "startTime": {
          "type": "number",
          "description": "Timestamp when the session started."
        },
        "endTime": {
          "type": "number",
          "description": "Timestamp when the session ended."
        },
        "locationName": {
          "type": "string",
          "description": "A user-defined name for the session location."
        }
      },
      "required": [
        "id",
        "userId",
        "startTime"
      ]
    },
    "NetworkSignal": {
      "title": "NetworkSignal",
      "type": "object",
      "description": "Represents a network signal data point with its location and strength.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the NetworkSignal entity."
        },
        "latitude": {
          "type": "number",
          "description": "The latitude of the network signal data point."
        },
        "longitude": {
          "type": "number",
          "description": "The longitude of the network signal data point."
        },
        "signalStrength": {
          "type": "number",
          "description": "The signal strength at the given latitude and longitude, ranging from 0 to 100."
        },
        "timestamp": {
          "type": "object",
          "description": "The server timestamp of the network signal measurement."
        }
      },
      "required": [
        "id",
        "latitude",
        "longitude",
        "signalStrength",
        "timestamp"
      ]
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": {
        "$ref": "#/entities/Session"
      },
      "description": "Stores session data for each user."
    },
    "/users/{userId}/sessions/{sessionId}/signals/{signalId}": {
      "schema": {
        "$ref": "#/entities/NetworkSignal"
      },
      "description": "Stores network signal data for each session."
    }
  }
}