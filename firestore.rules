/**
 * @file Firebase Security Rules for Firestore.
 *
 * @core_philosophy:
 * This ruleset provides open read access to network signal data while restricting write access.
 *
 * @data_structure:
 * All network signal data is stored in a top-level collection called `network_signals`.
 * Documents within this collection represent individual network signal data points.
 *
 * @key_security_decisions:
 * - Public Read: Read access (get, list) is granted to everyone, including unauthenticated users.
 * - Restricted Writes: Create, update, and delete operations are denied to all users.
 * - This configuration is suitable for a crowdsourced data collection scenario where the primary
 *   goal is to visualize data, and write access is managed through other secure mechanisms
 *   (e.g., a backend service or Firebase Functions with appropriate authentication and authorization).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants public read access to network signal data and restricts write access.
     * @path /network_signals/{networkSignalId}
     * @allow (get, list) Anyone can read network signal data.
     * @deny (create, update, delete) No one can create, update, or delete network signal data directly via the client.
     * @principle Allows public read access for data visualization while restricting unauthorized modifications.
     */
    match /network_signals/{networkSignalId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}