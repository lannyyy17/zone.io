/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for data access.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Only the authenticated user can read/write their own profile.
 * - /users/{userId}/sessions/{sessionId}: Stores session data for each user. Only the authenticated user can read/write their own sessions.
 * - /users/{userId}/sessions/{sessionId}/signals/{signalId}: Stores network signal data for each session. Only the authenticated user can read/write their own signal data.
 *
 * Key Security Decisions:
 * - User profiles and associated data are private and accessible only to the authenticated user.
 * - Listing of users is not allowed.
 *
 * Denormalization for Authorization:
 * - The 'userId' field in Session documents is used for authorization, ensuring only the owner can manage sessions.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (create) - Authenticated user with matching userId in the document.
     * @allow (get,update,delete) - Authenticated user accessing their own profile.
     * @deny (create) - Authenticated user trying to create a profile with a different userId.
     * @deny (get,update,delete) - Unauthenticated user trying to access a user profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows a user to manage their own sessions.
     * @path /users/{userId}/sessions/{sessionId}
     * @allow (create) - Authenticated user creating a new session under their user ID.
     * @allow (get,list,update,delete) - Authenticated user accessing their own sessions.
     * @deny (create) - Authenticated user trying to create a session under a different user ID.
     * @deny (get,list,update,delete) - Unauthenticated user or authenticated user trying to access another user's sessions.
     * @principle Enforces strict user ownership for all operations.
     */
    match /users/{userId}/sessions/{sessionId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows a user to manage network signal data for their own sessions.
     * @path /users/{userId}/sessions/{sessionId}/signals/{signalId}
     * @allow (create) - Authenticated user creating signal data under their session.
     * @allow (get,list,update,delete) - Authenticated user accessing their own signal data.
     * @deny (create) - Authenticated user trying to create signal data under another user's session.
     * @deny (get,list,update,delete) - Unauthenticated user or authenticated user trying to access another user's signal data.
     * @principle Enforces strict user ownership for all operations.
     */
    match /users/{userId}/sessions/{sessionId}/signals/{signalId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}