/**
 * @fileoverview Firestore Security Rules for the Network Signal Data App.
 *
 * Core Philosophy:
 * This ruleset allows public read access to all network signal data, while restricting write access.
 *
 * Data Structure:
 * All network signal data is stored in the top-level `/network_signals/{networkSignalId}` collection.
 * Each document represents a single network signal data point.
 *
 * Key Security Decisions:
 * - Public read access is granted to allow for map visualization.
 * - Write access is denied to prevent unauthorized data modification.
 * - No user-specific or role-based access controls are implemented, aligning with the crowdsourced nature of the data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants public read access to network signal data and restricts write access.
     * @path /network_signals/{networkSignalId}
     * @allow (get, list) Any user can read network signal data.
     * @deny (create, update, delete) No user can write to network signal data.
     * @principle Allows public read access while restricting write access.
     */
    match /network_signals/{networkSignalId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}